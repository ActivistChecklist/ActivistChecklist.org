# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/

# production
/build
/out
/out-dev

# misc
.DS_Store
*.pem
.agents
.claude
package-lock.json

# IDE related
.idea
.cursorrules
.cursor/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# vercel
.vercel

# pagefind (search indexing tool)
public/pagefind

/pages/playground.js*
/playground
**/playground/***
.image-cache.json

# URL scanner
.approved-urls.json

# Backups
buildbackups/

# Generated OG share images
public/images/og/

# Metadata cleaner folder
metadata-cleaner/

# SSL check log
.ssl-check.log

# Deploy/upload script (host-specific, not committed)
scripts/deploy-remote.sh

# GitHub deploy webhook secrets (repo root; loaded by public/webhooks/deploy.php)
deploy-webhook.config.local.php

# Deploy lock file (flock in scripts/build_deploy.sh)
.build_deploy.lock

# GitHub webhook deploy log (default path written by public/webhooks/deploy.php)
.deploy-webhook.log
