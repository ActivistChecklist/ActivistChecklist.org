# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/

# production
/build
/out
/out-dev

# misc
*.tsbuildinfo
.DS_Store
*.pem
.agents
.claude
package-lock.json

# IDE related
.idea
.cursorrules
.cursor/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# local env files
.env*
!.env.template

# vercel
.vercel

# pagefind (search indexing tool)
public/pagefind

/pages/playground.js*
/playground
**/playground/***
.image-cache.json

# URL scanner
.approved-urls.json

# Backups
buildbackups/

# Generated OG share images
public/images/og/

# Metadata cleaner folder
metadata-cleaner/

# SSL check log
.ssl-check.log

# GitHub deploy webhook secrets (local/server-only; never commit)
public/webhooks/webhook-secrets.local.php
public/webhooks/deploy-webhook.error.log

# Deploy lock file (flock in scripts/build-deploy.sh)
.build-deploy.lock

# GitHub webhook deploy log (default path written by public/webhooks/deploy.php)
.deploy-webhook.log
.deploy-webhook-auth.log
