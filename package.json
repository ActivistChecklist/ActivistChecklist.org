    "concurrently": "^9.2.1",
    "fastify-cli": "^7.4.1",
    "feed": "^5.2.0",
    "http-server": "^14.1.1",
    "js-yaml": "^4.1.1",
    "local-ssl-proxy": "^2.0.5",
    "next-sitemap": "^4.2.3",
    "node-fetch": "^3.3.2",
    "open-graph-scraper": "^6.11.0",
    "pagefind": "^1.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react-json-view": "^1.21.3",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
