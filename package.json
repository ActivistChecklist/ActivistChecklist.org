{
  "name": "activistchecklist",
  "version": "1.0.0",
  "description": "ActivistChecklist.org",
  "license": "GPL-3.0",
  "private": true,
  "scripts": {
    "prepare": "sh scripts/install-hooks.sh",
    "start": "next start",
    "clean": "rm -rf .next build node_modules out && yarn cache clean && yarn install",
    "dev": "concurrently -n \"API,PROXY,NEXT\" -c \"blue,yellow,green\" \"NODE_NO_WARNINGS=1 yarn api:dev\" \"NODE_NO_WARNINGS=1 local-ssl-proxy --source 3001 --target 3000\" \"yarn next dev\"",
    "next:dev": "next dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch-news": "node scripts/fetch-news-images.js",
    "news": "node scripts/news-wizard.js",
    "metadata": "node scripts/metadata-cli.cjs",
    "keystatic:format-mdx": "node scripts/keystatic-format-mdx.mjs",
    "prebuild": "node scripts/check-translations.mjs --strict && (yarn audit --level high || true)",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "buildstatic": "BUILD_MODE=static yarn build && yarn checkbuild && yarn check-links && yarn validate-build",
    "postbuild": "bash scripts/postbuild.sh",
    "og-images": "node scripts/generate-og-images.mjs",
    "og-images:clean": "node scripts/generate-og-images.mjs --clean",
    "index": "NODE_ENV=${NODE_ENV} bash scripts/build-search-index.sh",
    "rss": "node scripts/generate-rss.mjs",
    "buildbackup": "node scripts/build-backup.js",
    "check-links": "node scripts/check-links.mjs",
    "check-ssl": "bash scripts/check-ssl.sh",
    "check-build": "node scripts/check-build.mjs",
    "validate-build": "node scripts/validate-build.mjs",
    "serve": "npx serve out",
    "deploy": "bash scripts/deploy.sh",
    "deploy:remote": "bash scripts/deploy-remote.sh",
    "deploy:secrets": "bash scripts/deploy-secrets.sh",
    "snapshot": "node scripts/snapshot.mjs",
    "snapshot-normalize": "node scripts/snapshot-normalize.mjs",
    "snapshot-compare": "node scripts/snapshot-compare.mjs",
    "api:dev": "source .env && fastify start --watch --ignore-watch '.git node_modules out .next content public scripts utils styles pages config compontents' --log-level info --pretty-logs --port ${API_PORT:-4321} api/server.js",
    "api:start": "yarn run pm2 start ecosystem.config.js",
    "api:stop": "yarn run pm2 stop ac-api",
    "api:restart": "yarn run pm2 restart ac-api",
    "api:status": "yarn run pm2 status ac-api",
    "api:delete": "yarn run pm2 delete ac-api",
    "api:logs": "yarn run pm2 logs ac-api"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@keystatic/core": "^0.5.49",
    "@keystatic/next": "^5.0.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
