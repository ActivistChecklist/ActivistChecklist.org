#!/bin/sh

# Strip metadata from staged media files (images, PDFs, videos)
node scripts/pre-commit-metadata.cjs

if [ $? -ne 0 ]; then
  exit 1
fi

# Trailing slashes on internal paths (matches next.config trailingSlash + CI)
STAGED_PATH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(mdx|md|js|jsx|ts|tsx|mjs|cjs|json|yaml|yml)$' || true)
if [ -n "$STAGED_PATH_FILES" ]; then
  echo "Fixing trailing slashes on internal paths..."
  node scripts/trailing-slash-paths.mjs --fix --git-staged
  if [ $? -ne 0 ]; then
    exit 1
  fi
  echo "$STAGED_PATH_FILES" | while IFS= read -r f; do
    [ -n "$f" ] && git add -- "$f"
  done
fi

echo "Running tests before commit..."
yarn test

if [ $? -ne 0 ]; then
  echo "Tests failed. Commit aborted."
  exit 1
fi
